# Curator Environment Variables Template
# Copy this file to .env and fill in your values

# Claude Haiku API for genre classification (optional)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram notifications (optional)
# Create a bot: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get your chat ID: https://api.telegram.org/bot<YourBOTToken>/getUpdates
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Email notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
# For Gmail, use an app password: https://support.google.com/accounts/answer/185833
SMTP_PASS=your_app_password_here

# Spotify API for concert tracking (optional)
# Create app at: https://developer.spotify.com/dashboard
# IMPORTANT: Use 127.0.0.1 as redirect URI (not localhost)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Ticketmaster API for concert data (optional)
# Get free API key at: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# Custom paths (optional)
# CURATOR_CONFIG=./config.json
# CURATOR_DB=./curator.db
